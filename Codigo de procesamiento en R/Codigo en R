## Cargar matriz génica normalizada por DESeq2
df_genes <- read.csv("matriz_genes_normalizada_por_DESeq2.csv")

## Definir nombres de genes
rownames(df_genes) <- df_genes[,1]

## Eliminar primera columna
df_genes <- df_genes[,-1]

## Convertir a matriz
mat <- as.matrix(df_genes)

## Anotación de grupos
grupo <- c(
  "Obeso",
  "Obeso",
  "Normopeso",
  "Normopeso",
  "Normopeso"
)

ha_col <- HeatmapAnnotation(
  Grupo = grupo,
  col = list(
    Grupo = c(
      "Obeso" = "indianred",
      "Normopeso" = "steelblue"
    )
  )
)

## Escala de colores
rng <- range(mat, na.rm = TRUE)
mid <- median(mat, na.rm = TRUE)

col_fun <- colorRamp2(
  c(rng[1], mid, rng[2]),
  c("#4575B4", "#F7F7F7", "#D73027")
)



## Heatmap
Heatmap(
  mat,
  name = "Expresión",
  top_annotation = ha_col,
  col = col_fun,
  cluster_rows = TRUE,
  cluster_columns = TRUE,
  show_row_names = TRUE,
  show_column_names = TRUE,
  column_title = "Expresión génica",
  heatmap_legend_param = list(
    title_gp = gpar(fontsize = 10, fontface = "bold"),
    labels_gp = gpar(fontsize = 8)
  )
)

















